{
  "name": "wealth-checker",
  "version": "0.1.0",
  "private": true,
  "description": "Personal financial tracking platform — web + mobile",
  "scripts": {
    "dev": "concurrently \"npm:backend:dev\" \"npm:web:dev\"",
    "backend:dev": "cd backend && npm run dev",
    "web:dev": "cd web && npm run dev",
    "mobile:start": "cd mobile && npm start",
    "lint": "npm run lint -w backend -w web",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\" --ignore-path .gitignore"
  },
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "shared"
  ],
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prettier": "^3.1.0"
  },
  "dependencies": {
    "@expo/webpack-config": "^19.0.1",
    "react-native-web": "^0.19.13"
  }
}
